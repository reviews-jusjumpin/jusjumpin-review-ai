# ── Claude (reply generation + classification) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-8

# ── Google OAuth (Business Profile + Sheets) ──────────────────────────────────
# Create OAuth client (Desktop type) in Google Cloud Console, then run:
#   npm run get-token
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# GBP account that owns the location group with all 20 stores.
# Find it with: GET https://mybusinessaccountmanagement.googleapis.com/v1/accounts
GBP_ACCOUNT_ID=

# ── Ticket log (Google Sheet) ─────────────────────────────────────────────────
# Spreadsheet with a tab named "Tickets" (header row created automatically)
TICKET_SPREADSHEET_ID=
TICKET_SHEET_NAME=Tickets

# ── WhatsApp Cloud API alerts ─────────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
# Central ops number (always alerted, in addition to the store manager)
OPS_WHATSAPP=91XXXXXXXXXX
# Optional pre-approved template name (required for business-initiated messages)
WHATSAPP_TEMPLATE=review_alert

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
# Shared secret for Cloud Scheduler endpoints (sent as X-Tasks-Secret header)
TASKS_SECRET=change-me
# Set to 1 to log actions instead of posting replies / tickets / alerts
DRY_RUN=0
